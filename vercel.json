{
    "version": 2,
    "public": true,
    "name": "parsehub-dashboard",
    "builds": [
        {
            "src": "frontend/package.json",
            "use": "@vercel/next"
        }
    ],
    "routes": [
        {
            "src": "/(.*)",
            "dest": "frontend/$1"
        }
    ]
}